# ---- Supabase (apenas Auth + CRM: clients, contracts, tasks, leads, processes, cora, gclick, payroll) ----
# Nao armazenamos dados do modulo financeiro no REST deste projeto.
VITE_SUPABASE_PROJECT_ID="rvekakbpmkemgiwkkdok"
VITE_SUPABASE_URL="https://rvekakbpmkemgiwkkdok.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""

# ---- Postgres financeiro (PostgREST) — OBRIGATORIO para fluxo de caixa, contas, cartoes, faturas ----
# URL publica do PostgREST (EasyPanel). Ex: https://finance.seudominio.com.br
# Sem estas variaveis, o modulo financeiro fica indisponivel (nao ha fallback para tabelas no Supabase).
VITE_LOCAL_DB_URL=""

# JWT com payload {"role":"anon"}, assinado com o JWT_SECRET do Supabase (mesmo segredo do PostgREST PGRST_JWT_SECRET).
# Gerar: node -e "const j=require('jsonwebtoken');console.log(j.sign({role:'anon'},'<SECRET>',{expiresIn:'10y'}))"
VITE_LOCAL_DB_ANON_KEY=""

# Docker/EasyPanel (runtime): pode usar estes nomes em vez de VITE_* no Environment do container:
# FINANCE_POSTGREST_URL, FINANCE_POSTGREST_ANON_KEY
# LOCAL_DB_URL, LOCAL_DB_ANON_KEY
# POSTGREST_URL, POSTGREST_ANON_KEY
